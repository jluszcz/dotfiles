#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///

import argparse
import re
import shlex
import subprocess
import sys
from pathlib import Path

SYNOLOGY = "jluszcz@synology.local"
PLEX_BASE = "/volume1/Plex/Library"


def load_config(path):
    config = {}
    with open(path) as f:
        for line in f:
            line = line.split('#')[0].strip()
            if '=' not in line:
                continue
            key, _, value = line.partition('=')
            config[key.strip()] = value.strip()
    return config


def file_display(names):
    if len(names) == 1:
        return names[0]

    prefix = names[0]
    for name in names[1:]:
        while prefix and not name.startswith(prefix):
            prefix = prefix[:-1]

    suffix = names[0]
    for name in names[1:]:
        while suffix and not name.endswith(suffix):
            suffix = suffix[1:]

    if len(prefix) + len(suffix) >= min(len(n) for n in names):
        return ', '.join(names)

    middles = []
    for name in names:
        mid = name[len(prefix):]
        if suffix:
            mid = mid[:-len(suffix)]
        middles.append(mid)

    return f"{prefix}[{', '.join(middles)}]{suffix}"


def detect_show_season(files):
    pattern = re.compile(r'^(.+) - s(\d+)e\d+')
    show = season = None
    for f in files:
        m = pattern.match(f.stem)
        if not m:
            return None, None
        s, n = m.group(1), int(m.group(2))
        if show is None:
            show, season = s, n
        elif s != show or n != season:
            return None, None
    return show, season


def main():
    parser = argparse.ArgumentParser(prog='plex-sync', description='Sync media to Plex on Synology')
    parser.add_argument('-c', dest='config_file', metavar='config_file')
    media = parser.add_mutually_exclusive_group()
    media.add_argument('-m', dest='media_type', action='store_const', const='movies')
    media.add_argument('-t', dest='media_type', action='store_const', const='tv')
    parser.add_argument('-n', dest='show_name', metavar='name')
    parser.add_argument('-s', dest='season', metavar='number', type=int)
    parser.add_argument('-d', dest='dry_run', action='store_true')
    parser.add_argument('-o', dest='overwrite', action='store_true')
    parser.add_argument('directory')
    args = parser.parse_args()

    directory = Path(args.directory.rstrip('/'))
    if not directory.is_dir():
        print(f"Error: '{directory}' is not a directory.", file=sys.stderr)
        sys.exit(1)

    config_path = Path(args.config_file) if args.config_file else directory / '.plex-sync'
    if args.config_file and not config_path.is_file():
        print(f"Error: Config file '{config_path}' not found.", file=sys.stderr)
        sys.exit(1)

    media_type = show_name = None
    season = None

    if config_path.is_file():
        cfg = load_config(config_path)
        media_type = cfg.get('MEDIA_TYPE')
        show_name = cfg.get('SHOW_NAME')
        if s := cfg.get('SEASON'):
            try:
                season = int(s)
            except ValueError:
                print(f"Error: Invalid SEASON value '{s}' in config.", file=sys.stderr)
                sys.exit(1)
        print(f"Loaded config: {config_path}")

    if args.media_type:
        media_type = args.media_type
    if args.show_name:
        show_name = args.show_name
    if args.season is not None:
        season = args.season

    mkv_files = sorted(directory.glob('*.mkv'))
    if not mkv_files:
        print(f"No .mkv files found in '{directory}'.", file=sys.stderr)
        sys.exit(1)

    if not media_type:
        print("Media type:\n  1) Movies\n  2) TV Shows")
        choice = input("Choice [1/2]: ").strip()
        if choice in ('1',) or choice.lower().startswith('m'):
            media_type = 'movies'
        elif choice in ('2',) or choice.lower().startswith('t'):
            media_type = 'tv'
        else:
            print("Error: Invalid choice.", file=sys.stderr)
            sys.exit(1)

    names = [f.name for f in mkv_files]

    if media_type.lower().startswith('m'):
        target = f"{PLEX_BASE}/Movies"
        display = f"…/Movies/{file_display(names)}"
    elif media_type.lower().startswith('t'):
        if not show_name or season is None:
            detected_show, detected_season = detect_show_season(mkv_files)
            if detected_show:
                if not show_name:
                    show_name = detected_show
                if season is None:
                    season = detected_season
                print(f"Detected: {show_name}, Season {season}")
        if not show_name:
            show_name = input("Show name: ").strip()
        if season is None:
            try:
                season = int(input("Season number: ").strip())
            except ValueError:
                print("Error: Season number must be an integer.", file=sys.stderr)
                sys.exit(1)
        season_padded = f"{season:02d}"
        target = f"{PLEX_BASE}/TV Shows/{show_name}/Season {season_padded}"
        display = f"…/TV Shows/{show_name}/Season {season_padded}/{file_display(names)}"
    else:
        print("Error: Invalid media type.", file=sys.stderr)
        sys.exit(1)

    print(f"\nTarget: {SYNOLOGY}:{display}\n")

    if args.dry_run:
        print(f"[dry run] Would create remote directory: {SYNOLOGY}:{target}/")
        for f in mkv_files:
            if args.overwrite:
                print(f"[dry run] Would delete: {SYNOLOGY}:{target}/{f.name}")
            print(f"[dry run] Would rsync: {f} -> {SYNOLOGY}:{target}/")
            print(f"[dry run] Would delete local: {f}")
        print(f"[dry run] Would remove directory: {directory}")
        print("Done (dry run).")
        return

    if input("Proceed? [y/N]: ").strip().lower() != 'y':
        print("Aborted.")
        return

    try:
        subprocess.run(['ssh', SYNOLOGY, f"mkdir -p {shlex.quote(target)}"], check=True)

        for f in mkv_files:
            if args.overwrite:
                subprocess.run(['ssh', SYNOLOGY, f"rm -f {shlex.quote(f'{target}/{f.name}')}"], check=True)
            subprocess.run(
                ['rsync', '-avz', '--progress', '--protect-args', str(f), f"{SYNOLOGY}:{target}/"],
                check=True,
            )
            f.unlink()
    except subprocess.CalledProcessError as e:
        print(f"Error: Command failed: {' '.join(str(x) for x in e.cmd)}", file=sys.stderr)
        sys.exit(1)

    if not any(p for p in directory.iterdir() if p.name != '.DS_Store'):
        (directory / '.DS_Store').unlink(missing_ok=True)

    try:
        directory.rmdir()
    except OSError:
        print("Warning: Directory not empty, skipping removal.")

    print("Done - Consider running 'tmclean' to reclaim space")


if __name__ == '__main__':
    main()
