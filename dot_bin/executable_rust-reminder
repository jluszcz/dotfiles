#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///

"""Create an Apple Reminder to update Rust for the next release.

Prompts for the next release date (look it up at https://releases.rs), then
schedules a "Update Rust" reminder for 10am on the Saturday following that date,
with the releases URL in the body.

macOS only (uses the Reminders app via AppleScript).
"""

import datetime
import subprocess
import sys

RELEASES_URL = "https://releases.rs"


def prompt_date():
    print(f"Look up the next Rust release at {RELEASES_URL}")
    raw = input("Release date (YYYY-MM-DD, blank to skip): ").strip()
    if not raw:
        return None
    try:
        return datetime.date.fromisoformat(raw)
    except ValueError:
        print(f"Error: '{raw}' is not a valid date (expected YYYY-MM-DD).", file=sys.stderr)
        sys.exit(1)


def following_saturday(date):
    """Return the first Saturday strictly after date."""
    days_ahead = (5 - date.weekday()) % 7  # Monday=0 .. Saturday=5
    if days_ahead == 0:
        days_ahead = 7
    return date + datetime.timedelta(days=days_ahead)


def create_reminder(name, url, when):
    # AppleScript dates are locale-sensitive to parse, so build one field by
    # field. Reminders has no scriptable URL field, so the URL goes in the body
    # (macOS renders it as a tappable link).
    script = f'''
set d to current date
set hours of d to 10
set minutes of d to 0
set seconds of d to 0
set day of d to 1
set year of d to {when.year}
set month of d to {when.month}
set day of d to {when.day}
tell application "Reminders"
    make new reminder with properties {{name:"{name}", body:"{url}", remind me date:d, due date:d}}
end tell
'''
    subprocess.run(["osascript", "-e", script], check=True)


def main():
    release_date = prompt_date()
    if not release_date:
        print("Skipped - no reminder created.")
        return

    reminder_date = following_saturday(release_date)

    create_reminder("Update Rust", RELEASES_URL, reminder_date)

    print(f"\nReminder set: 'Update Rust' on {reminder_date:%A, %Y-%m-%d} at 10:00am")
    print(f"  {RELEASES_URL}")


if __name__ == "__main__":
    main()
