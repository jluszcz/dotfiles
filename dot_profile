export PATH=$HOME/.bin:$PATH

short_pwd() {
    local pwd="${PWD/#$HOME/~}"
    printf '%s' "$pwd" | awk -F'/' 'NF>2{print $(NF-1)"/"$NF; next} {print}'
}

PS1='\[\033[1m\][Synology]\[\033[0m\] $(short_pwd) » '

eval $(dircolors $HOME/.dircolors)

alias l=ls
alias ll='ls -lh'

alias rc="rclone sync /volume1/Plex/Library s3-media:jluszcz-physical-media --exclude .DS_Store --exclude '@eaDir/**' --progress"
alias t='tmux-attach'
