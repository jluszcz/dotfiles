#!/usr/bin/env sh

{{- if eq .chezmoi.os "darwin" }}
# Symlink preferences into the right places
SUBLIME_PREFS_DIR="{{ .chezmoi.homeDir }}/Library/Application Support/Sublime Text/Packages/User"
if [ -d "${SUBLIME_PREFS_DIR}" ]; then
    rm -f "${SUBLIME_PREFS_DIR}/Preferences.sublime-settings"
    ln -svfh {{ .chezmoi.homeDir }}/.config/Sublime.json "${SUBLIME_PREFS_DIR}/Preferences.sublime-settings"
fi

VSCODE_PREFS_DIR="{{ .chezmoi.homeDir }}/Library/Application\ Support/Code/User"
if [ -d "${VSCODE_PREFS_DIR}" ]; then
    rm -f "${VSCODE_PREFS_DIR}/settings.json"
    ln -svfh {{ .chezmoi.homeDir }}/.config/VSCode.json "${VSCODE_PREFS_DIR}/settings.json"
fi

# Symlink Dropbox folders into ~/Documents
if [ -d {{ .chezmoi.homeDir }}/Dropbox ]; then
    ln -svfh {{ .chezmoi.homeDir }}/Dropbox/Career/Amazon {{ .chezmoi.homeDir }}/Documents/
    ln -svfh {{ .chezmoi.homeDir }}/Dropbox/Career/Netflix {{ .chezmoi.homeDir }}/Documents/
    ln -svfh {{ .chezmoi.homeDir }}/Dropbox/Career {{ .chezmoi.homeDir }}/Documents/
    ln -svfh {{ .chezmoi.homeDir }}/Dropbox/Money {{ .chezmoi.homeDir }}/Documents/
fi

# Copy Obsidian files into ~/Dropbox
if [ -d {{ .chezmoi.homeDir }}/Dropbox ]; then
    mkdir -p {{ .chezmoi.homeDir }}/Dropbox/Obsidian/Templates
    rm -f {{ .chezmoi.homeDir }}/Dropbox/Obsidian/Templates/Daily\ Template.md
    cp {{ .chezmoi.homeDir }}/.obsidian/Daily\ Template.md {{ .chezmoi.homeDir }}/Dropbox/Obsidian/Templates/
fi

# Symlink .env files into their projects
if [ -d {{ .chezmoi.homeDir }}/Documents/Programs/EndTimes ]; then
    rm -f {{ .chezmoi.homeDir }}/Documents/Programs/EndTimes/.dev.vars
    ln -svfh {{ .chezmoi.homeDir }}/.config/envrc/endtimes {{ .chezmoi.homeDir }}/Documents/Programs/EndTimes/.dev.vars
fi

if [ -d {{ .chezmoi.homeDir }}/Documents/Programs/JakeSky-rs ]; then
    rm -f {{ .chezmoi.homeDir }}/Documents/Programs/JakeSky-rs/.envrc
    ln -svfh {{ .chezmoi.homeDir }}/.config/envrc/jakesky {{ .chezmoi.homeDir }}/Documents/Programs/JakeSky-rs/.envrc
fi

if [ -d {{ .chezmoi.homeDir }}/Documents/Programs/LottoCheck ]; then
    rm -f {{ .chezmoi.homeDir }}/Documents/Programs/LottoCheck/.dev.vars
    ln -svfh {{ .chezmoi.homeDir }}/.config/envrc/lottocheck {{ .chezmoi.homeDir }}/Documents/Programs/LottoCheck/.dev.vars
fi

if [ -d {{ .chezmoi.homeDir }}/Documents/Programs/mbtalerts ]; then
    rm -f {{ .chezmoi.homeDir }}/Documents/Programs/mbtalerts/.envrc
    ln -svfh {{ .chezmoi.homeDir }}/.config/envrc/mbtalerts {{ .chezmoi.homeDir }}/Documents/Programs/mbtalerts/.envrc
fi

if [ -d {{ .chezmoi.homeDir }}/Documents/Programs/Seen ]; then
    rm -f {{ .chezmoi.homeDir }}/Documents/Programs/Seen/.dev.vars
    ln -svfh {{ .chezmoi.homeDir }}/.config/envrc/seen {{ .chezmoi.homeDir }}/Documents/Programs/Seen/.env
fi
# End .env files

# Symlink oh-my-zsh theme
THEME_DIR="{{ .chezmoi.homeDir }}/.oh-my-zsh/custom/themes"
if [ -d "${THEME_DIR}" ]; then
    ln -svfh {{ .chezmoi.homeDir }}/.config/gallifrey-custom.zsh-theme "${THEME_DIR}"/
fi
{{- end }}

{{- if eq .chezmoi.hostname "Synology" }}
ln -svf /var/packages/Git/target/bin/git {{ .chezmoi.homeDir }}/.bin/git
{{- end }}
